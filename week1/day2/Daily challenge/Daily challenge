# exact_10_string.py
def check_string_length(s: str) -> str:
    """
    Check whether a string is exactly 10 characters long.

    Returns:
      - "Perfect string" if len(s) == 10
      - "String not long enough." if len(s) < 10
      - "String too long." if len(s) > 10
    """
    # get the number of characters in the string
    n = len(s)

    # compare length to 10 and return appropriate message
    if n < 10:
        return "String not long enough."
    elif n > 10:
        return "String too long."
    else:
        return "Perfect string"

def main_interactive():
    """
    Interactive script: prompts the user to enter a string, checks length, prints result.
    """
    user_input = input("Enter a string (must be exactly 10 characters): ")
    result = check_string_length(user_input)
    print(result)

# To run interactively in VS Code, change the next line to:
# if __name__ == "__main__":
# (remove the "and False")
if __name__ == "__main__" and False:
    main_interactive()

