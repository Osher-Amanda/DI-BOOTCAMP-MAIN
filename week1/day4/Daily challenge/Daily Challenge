# =========================
# Matrix Decoding Exercise
# =========================

# Step 0: Original matrix string
MATRIX_STR = '''
7ir
Tsi
h%x
i ?
sM# 
$a 
#t%'''  # The raw string representing the matrix

# =========================
# Step 1: Transform string into a 2D list (matrix)
# =========================

# Remove leading/trailing whitespace and split into rows
rows = MATRIX_STR.strip().split('\n')  # split string by newline

# Convert each row into a list of characters
matrix = [list(row) for row in rows]  # each row is now a list of chars

# =========================
# Step 2: Process columns
# =========================

# Determine number of rows and columns
num_rows = len(matrix)
num_cols = len(matrix[0])  # assuming all rows have same length

# Initialize empty list to collect characters column by column
col_chars = []

# Iterate over columns
for col in range(num_cols):
    for row in range(num_rows):
        col_chars.append(matrix[row][col])  # read top to bottom

# =========================
# Step 3: Filter alpha characters
# =========================

# Initialize empty string to hold alpha characters and symbols
message_with_symbols = ''.join(col_chars)  # join all characters in column order

# =========================
# Step 4: Replace symbols with spaces
# =========================

decoded_message = ""      # final message
prev_char_alpha = False   # flag to track previous character

for ch in message_with_symbols:
    if ch.isalpha():             # if the character is a letter
        if not prev_char_alpha and decoded_message and decoded_message[-1] != ' ':
            # if previous was symbol and we already have letters, add space
            decoded_message += ' '
        decoded_message += ch    # add the alpha character
        prev_char_alpha = True   # update flag
    else:
        prev_char_alpha = False  # mark that current char is not alpha

# Step 5: Print the decoded message
print("=== Decoded Message ===")
print(decoded_message)

# Step 0: MATRIX_STR contains the raw multiline string of the matrix.
# Step 1: .strip() removes leading/trailing newlines; .split('\n') splits the string into rows.
# Step 1: matrix = [list(row) for row in rows] converts each row into a list of characters.
# Step 2: Determine number of rows and columns for iteration.
# Step 2: Iterate columns first, then rows inside, to read top-to-bottom column-wise.
# Step 3: Join all column-wise characters into a single string.
# Step 4: Loop through the string and keep only alpha characters.
# Step 4: Insert a space when a non-alpha character occurs between letters.
# Step 5: Print the final decoded message.