// Exercise 1: List of people

const people = ["Greg", "Mary", "Devon", "James"];

// Part I - Review about arrays
// 1. Remove "Greg" (the first element)
people.shift();

// 2. Replace "James" with "Jason"
people[people.indexOf("James")] = "Jason";

// 3. Add your name to the end
people.push("Alex");

// 4. Console.log Mary's index
console.log(people.indexOf("Mary"));

// 5. Copy using slice (excluding "Mary" and "Alex")
// Currently people is ["Mary", "Devon", "Jason", "Alex"]
// slice(1, 3) starts at index 1 and stops BEFORE index 3
const peopleCopy = people.slice(1, 3);

// 6. Index of "Foo"
console.log(people.indexOf("Foo")); 
// It returns -1 because "Foo" does not exist in the array.

// 7. Variable called last
const last = people[people.length - 1];

// Part II - Loops
// 1. Iterate and log everyone
for (let person of people) {
    console.log(person);
}

// 2. Exit loop after logging "Devon"
for (let person of people) {
    console.log(person);
    if (person === "Devon") {
        break; // Stops the loop completely
    }
}


