// Exercise 7: Secret Group

const names = ["Jack", "Philip", "Sarah", "Amanda", "Bernard", "Kyle"];
let acronym = "";

// 1. Get first letters
for (let name of names) {
    acronym += name[0];
}

// 2. Sort letters (we turn string into array, sort it, then join back)
const societyName = acronym.split("").sort().join("");
console.log(societyName);


